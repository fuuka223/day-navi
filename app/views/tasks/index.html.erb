<div class="container" data-controller="task-list">
  <header class="page-header">
    <h1>タスク一覧</h1>
  </header>

  <main class="task-matrix">
    <% matrix_definition = [
      { label: "重要・緊急", css: "important urgent" },
      { label: "重要・非緊急", css: "important not-urgent" },
      { label: "非重要・緊急", css: "not-important urgent" },
      { label: "非重要・非緊急", css: "not-important not-urgent" }
    ] %>

    <% matrix_definition.each_with_index do |panel, i| %>
      <section class="matrix-box <%= panel[:css] %>">
        <h2><%= panel[:label] %></h2>
        <div class="task-list">
          <%# 優先度と一致するタスクを抽出 %>
          <% @tasks.select { |t| t.priority_level_before_type_cast == (i + 1)}.each do |task| %>
            <% is_overdue = task.deadline.present? && task.deadline < Time.current && !task.is_completed %>
            <div class="task-card is-clickable" 
                 data-url="<%= task_path(task) %>"
                 data-completed="<%= task.is_completed %>"
                 data-overdue="<%= task.deadline.present? && task.deadline < Time.current && !task.is_completed %>">
              
              <div class="task-card-header">
                <%= button_to toggle_status_task_path(task), 
                            method: :patch, 
                            class: "status-btn js-toggle" do %>
                  <%= task.is_completed ? "✅" : "⬜️" %>
                <% end %>
                
                <%= link_to task.title, task_path(task), 
                            class: "task-title #{ 'completed' if task.is_completed } #{ 'overdue' if is_overdue }" %>
              </div>

              <% if task.deadline.present? %>
                <div class="task-deadline", if is_overdue %>
                  <% remaining_days = (task.deadline.to_date - Date.current).to_i %>

                  <% if is_overdue %>
                    <span>⚠️ 期限切れ<br>
                      　 （<%= remaining_days.abs %>日経過）</span>
                  <% elsif task.is_completed %>
                    <span style="color: gray;">期限: <%= l task.deadline, format: :short %></span>
                  <% elsif remaining_days == 0 %>
                    <span>🔥 今日が期限です！</span>
                  <% elsif remaining_days == 1 %>
                    <span>📢 あと 1 日（明日）</span>
                  <% else %>
                    <span>あと <%= remaining_days %> 日</span>
                  <% end %>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      </section>
    <% end %>
  </main>

  <%= link_to "+", new_task_path, class: "fab" %>
</div>