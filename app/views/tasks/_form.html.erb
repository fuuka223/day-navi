<%= form_with model: task, local: true, class: "task-form" do |f| %>
  <% if task.errors.any? %>
    <div class="error-messages">
      <ul>
        <% task.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-group">
    <%= f.label :title, "タイトル" %>
    <%= f.text_field :title, placeholder: "何をしますか？", class: "form-input" %>
  </div>

  <div class="form-group">
    <%= f.label :content, "内容" %>
    <%= f.text_area :content, rows: 4, placeholder: "詳細なメモなど", class: "form-input" %>
  </div>

  <div class="form-group">
    <%= f.label :priority_level, "優先度" %>
    <div class="select-wrapper">
      <%= f.select :priority_level, 
          [["重要・緊急", 0], ["重要・非緊急", 1], ["非重要・緊急", 2], ["非重要・非緊急", 3]], 
          {}, { class: "form-input" } %>
    </div>
  </div>

  <div class="form-group">
    <%= f.label :deadline, "期限" %>
    <%= f.datetime_field :deadline, class: "form-input" %>
  </div>

  <div class="form-group inline-group">
    <%= f.check_box :is_completed, class: "form-checkbox" %>
    <%= f.label :is_completed, "完了したタスクとして登録" %>
  </div>

  <div class="actions">
    <%= f.submit yield(:button_text), class: "submit-btn" %>
  </div>
<% end %>