<div class="profile-container">
  <h2>プロフィール設定</h2>

  <%= form_with(model: @user, local: true) do |f| %>
    <div class="profile-item">
      <label>名前</label>
      <p><%= @user.name %></p>
    </div>

    <div class="profile-item">
      <label>メールアドレス</label>
      <p><%= @user.email %></p>
    </div>

    <div class="profile-item">
      <label>パスワード</label>
      <p>********</p>
      <%= link_to "パスワード変更はこちら", edit_user_registration_path, class: "edit-link" %>
    </div>

    <div class="profile-item highlight">
      <%= f.label :location_id, "お住まいの市区町村（天気予報用）" %>
      <%= f.collection_select :location_id, Location.all, :id, :city, prompt: "お住まいの地域を選択してください" %>
    </div>

    <div class="actions">
      <%= f.submit "保存する", class: "save-button" %>
    </div>

  <% end %>
</div>

<div class="profile-container">
  <h2 class="section-title">アカウント管理</h3>

    <%# ログアウトボタン %>
    <div class="action-item">
      <%= button_to "ログアウト", destroy_user_session_path, 
                  method: :delete, 
                  class: "btn-logout",
                  form: {
                    data: {
                      turbo: false,
                      turbo_preload: false
                    }
                  } %>
    </div>

    <hr class="separator">

    <%# アカウント削除ボタン %>
    <%= button_to "アカウント削除", user_registration_path, 
            method: :delete, 
            data: {
              turbo_confirm: "本当にアカウントを削除しますか？この操作は戻せません。",
              turbo: true
            },
            class: "btn-danger" %>
    </div>
</div>