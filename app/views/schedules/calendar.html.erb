<div class="calendar-container">
  <div class="calendar-header">
    <h1>予定カレンダー</h1>
    <%= link_to '予定を追加', new_schedule_path, class: "btn-new" %>
  </div>

  <%= month_calendar(events: @schedules) do |date, schedules| %>
  <%= link_to schedule_path(date), class: "calendar-day-link" do %>
    <div class="calendar-day">
      <div class="day-header" style="position: relative;">
        <span class="day-number"><%= date.day %></span>
        
        <% if @forecasts && @forecasts[date] %>
          <div class="weather-overlay" title="<%= @forecasts[date][:description] %>">
            <%= image_tag "https://openweathermap.org/img/wn/#{@forecasts[date][:icon]}@2x.png", 
                          alt: @forecasts[date][:description],
                          class: "weather-icon" %>
          </div>
        <% end %>
      </div>

      <div class="schedule-list">
        <% schedules.each do |schedule| %>
          <div class="schedule-item">
            <small>●</small> <%= schedule.title.truncate(10) %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
<% end %>