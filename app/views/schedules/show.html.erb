<div class="schedule-detail-container">
  <div class="detail-header">
    <div class="header-left">
      <small class="calendar-year"><%= @date.year %>年</small>
      <strong class="calendar-month"><%= @date.month %>月<%= @date.day %>日</strong>
    </div>
    <%= link_to 'カレンダーに戻る', schedules_path, class: "btn-back" %>
  </div>

  <div class="timeline-wrapper" id="timeline">
    <%# 背景のメモリ %>
    <div class="timeline-grid" onclick="createNewSchedule(event)">
      <% (0..24).each do |hour| %>
        <div class="grid-row" style="top: <%= hour * 60 %>px;" data-hour="<%= hour %>">
          <div class="grid-time"><%= sprintf("%02d:00", hour) %></div>
          <div class="grid-line"></div>
        </div>
      <% end %>
    </div>

    <%# 予定の帯 %>
    <div class="schedule-overlay">
      <% @schedules.each do |schedule| %>
        <% 
          top = schedule.start_time.hour * 60 + schedule.start_time.min
          height = (schedule.end_time - schedule.start_time) / 60
        %>
        <div class="swipe-container" style="top: <%= top %>px; height: <%= height %>px;">
          <%# スライド時に後ろから見えるボタン %>
          <div class="swipe-actions">
            <%# 編集ボタン %>
            <%= link_to edit_schedule_path(schedule), class: 'btn-edit' do %>
              <i class="fa-solid fa-pen"></i>
            <% end %>
            <%# 削除ボタン %>
            <%= link_to schedule_path(schedule), 
                class: 'btn-delete',
                data: { "turbo-method": :delete, "turbo-confirm": '本当に削除しますか？' } do %>
              <i class="fa-solid fa-trash-can"></i>
            <% end %>
          </div>
          <%# 表に見える予定の帯 %>
          <div class="schedule-bar-absolute swipe-content" 
               <%# 引数を4つ（title, time, content, event）に増やします %>
               onclick="showDetail('<%= j schedule.title %>', '<%= schedule.start_time.strftime("%H:%M") %>〜<%= schedule.end_time.strftime("%H:%M") %>', '<%= j schedule.content %>', event)"
               data-id="<%= schedule.id %>">
            <span class="schedule-title"><%= schedule.title %></span>
          </div>
        </div>
      <% end %>
    </div>
  </div>

  <%# 下3分の1の詳細ウィンドウ（1つだけに整理） %>
  <div id="bottom-sheet" class="bottom-sheet">
    <div class="sheet-handle" onclick="hideDetail()"></div>
    <div class="sheet-content">
      <div class="sheet-header">
        <h3 id="sheet-title"></h3>
        <div id="sheet-time" style="color: #6c5ce7; font-weight: 600; margin-bottom: 10px;"></div>
      </div>
    
      <div class="sheet-body">
        <div id="sheet-content" class="sheet-memo" style="white-space: pre-wrap; color: #636e72;"></div>
      </div>
    </div>
  </div>
</div>