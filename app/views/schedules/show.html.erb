<div class="schedule-details">
  <h2><%= @selected_date.strftime("%Y年%m月%d日") %> の予定一覧</h2>

  <div class="schedule-actions">
    <%= link_to 'この日に予定を追加', new_schedule_path(start_date: @selected_date) %>
    |
    <%= link_to 'カレンダーに戻る', calendar_schedules_path %>
  </div>

  <hr>

  <div class="schedule-list">
    <% if @schedules.any? %>
      <% @schedules.each do |schedule| %>
        <div class="schedule-card">
          <h3><%= schedule.title %></h3>
          
          <p>
            <strong>時間:</strong>
            <%= schedule.start_time.strftime("%H:%M") %> 〜 
            <%= schedule.end_time.strftime("%H:%M") if schedule.end_time %>
          </p>

          <p>
            <strong>内容:</strong><br>
            <%= simple_format(schedule.content) %>
          </p>

          <div class="item-actions">
            <%= link_to '編集', edit_schedule_path(schedule) %>
            |
            <%= link_to '削除', schedule_path(schedule), 
                        data: { turbo_method: :delete, turbo_confirm: '本当に削除しますか？' } %>
          </div>
          <hr>
        </div>
      <% end %>
    <% else %>
      <p>この日の予定はありません。</p>
    <% end %>
  </div>
</div>