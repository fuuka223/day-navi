<%= form_with model: schedule, local: true, class: "schedule-form" do |f| %>
  <% if schedule.errors.any? %>
    <div class="error-container">
      <ul>
        <% schedule.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-group">
    <%= f.label :title, "タイトル", class: "form-label" %>
    <%= f.text_field :title, class: "form-input", placeholder: "予定のタイトルを入力" %>
  </div>

  <div class="form-group">
    <%= f.label :content, "メモ", class: "form-label" %>
    <%= f.text_area :content, class: "form-textarea", placeholder: "詳細なメモを入力（任意）", rows: 4 %>
  </div>

  <div class="form-group">
    <%= f.label :start_date, "日付", class: "form-label" %>
    <%= f.date_field :start_date, 
                     value: f.object.start_time&.to_date || Date.today, 
                     class: "form-input js-time-picker" %>
  </div>

  <div class="time-range-group">
    <div class="form-group flex-1">
      <%= f.label :start_time, "開始", class: "form-label" %>
      <%= f.time_field :start_time, class: "form-input time-input js-time-picker" %>
    </div>
    <div class="time-separator">〜</div>
    <div class="form-group flex-1">
      <%= f.label :end_time, "終了", class: "form-label" %>
      <%= f.time_field :end_time, class: "form-input time-input js-time-picker" %>
    </div>
  </div>

  <div class="field">
    <%= f.label :category_name, "カテゴリー" %>
    <%= f.text_field :category_name, list: "category-list", id: "category-input", placeholder: "仕事、プライベートなど" %>
    <datalist id="category-list">
      <% @category_options.each do |option| %>
        <option value="<%= option.category_name %>" data-color="<%= option.category_color %>">
      <% end %>
    </datalist>
  </div>

  <div class="field">
    <%= f.label :category_color, "カテゴリーカラー" %>
    <div class="color-picker-wrapper">
      <%= f.color_field :category_color, id: "color-input", value: @schedule.category_color || "#cacaca" %>
      <span class="hint">予定ブロックの色に反映されます</span>
    </div>
  </div>

  <%# <script>
    // カテゴリー名が選択されたら、紐付いている色を自動反映させる
    document.getElementById('category-input').addEventListener('input', function(e) {
      const list = document.getElementById('category-list');
      const options = list.options;
      for (let i = 0; i < options.length; i++) {
        if (options[i].value === e.target.value) {
          document.getElementById('color-input').value = options[i].getAttribute('data-color');
          break;
        }
      }
    });
  </script> %>

  <div class="form-actions">
    <%= f.submit yield(:button_text), class: "btn-submit" %>
    <%= link_to 'キャンセル', :back, class: "btn-cancel" %>
  </div>
<% end %>