<%= form_with model: schedule, local: true, class: "schedule-form" do |f| %>
  <% if schedule.errors.any? %>
    <div class="error-container">
      <ul>
        <% schedule.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-group">
    <%= f.label :title, "タイトル", class: "form-label" %>
    <%= f.text_field :title, class: "form-input", placeholder: "予定のタイトルを入力" %>
  </div>

  <div class="form-group">
    <%= f.label :content, "メモ", class: "form-label" %>
    <%= f.text_area :content, class: "form-textarea", placeholder: "詳細なメモを入力（任意）", rows: 4 %>
  </div>

  <div class="time-range-group">
    <div class="form-group flex-1">
      <%= f.label :start_time, "開始", class: "form-label" %>
      <%= f.time_field :start_time, class: "form-input time-input js-time-picker" %>
    </div>
    <div class="time-separator">〜</div>
    <div class="form-group flex-1">
      <%= f.label :end_time, "終了", class: "form-label" %>
      <%= f.time_field :end_time, class: "form-input time-input js-time-picker" %>
    </div>
  </div>

  <div class="form-actions">
    <%= f.submit yield(:button_text), class: "btn-submit" %>
    <%= link_to 'キャンセル', :back, class: "btn-cancel" %>
  </div>
<% end %>